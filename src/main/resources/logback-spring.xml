<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <springProperty scope="context" name="WS_LOG_FILE" source="farm.logging.websocket.file-path" defaultValue="logs/farm-realtime.log"/>
    <springProperty scope="context" name="WS_LOG_LEVEL" source="farm.logging.websocket.level" defaultValue="DEBUG"/>

    <appender name="WS_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${WS_LOG_FILE}</file>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{48} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${WS_LOG_FILE}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
            <maxFileSize>20MB</maxFileSize>
            <maxHistory>14</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <logger name="cn.jxufe.farm.websocket" level="${WS_LOG_LEVEL}" additivity="false">
        <appender-ref ref="WS_FILE"/>
    </logger>
    <logger name="cn.jxufe.farm.service.imp.FarmRealtimePushServiceImp" level="${WS_LOG_LEVEL}" additivity="false">
        <appender-ref ref="WS_FILE"/>
    </logger>
    <logger name="cn.jxufe.farm.service.imp.CropStatusSchedulerServiceImp" level="${WS_LOG_LEVEL}" additivity="false">
        <appender-ref ref="WS_FILE"/>
    </logger>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
